mplate>\n\n<script setup>\n\n</script>\n\n<style lang=\"less\">\n.app-contacts {\n    .container;\n\n    &__wrapper {\n        display: flex;\n        align-items: center;\n        /* margin-bottom: 164px; */\n        @media @bw1020 {\n            flex-direction: column;\n        }\n        @media @bw1340 {\n            /* margin-bottom: 130px; */\n        }\n        @media @bw768 {\n            margin-bottom: 100px;\n        }\n    }\n    &__list {\n        flex-shrink: 0;\n        width: 400px;\n        margin: 0 30px 0 0;\n        padding: 0;\n        list-style: none;\n        @media @bw1020 {\n            order: 1;\n            width: 100%;\n            margin: 0;\n            display: flex;\n            align-items: flex-start;\n        }\n        @media @bw768 {\n            flex-direction: row;\n            margin-top: 100px;\n        }\n        @media @bw370 {\n            flex-direction: column;\n            align-items: flex-start;\n        }\n    }\n    &__item {\n        box-sizing: border-box;\n        display: flex;\n        align-items: center;\n        margin: 0 0 65px;\n        @media @bw1020 {\n            flex-direction: column;\n            width: 33%;\n            margin: 0;\n            padding: 0 10px;\n        }\n        @media @bw768 {\n            flex-direction: column;\n            align-items: center;\n            width: 100%;\n            margin: 0 0 45px;\n            padding: 0;\n        }\n        @media @bw370 {\n            flex-direction: row;\n            align-items: flex-start;\n        }\n        &:last-child {\n            margin: 0;\n        }\n    }\n    &__item-mark {\n        flex-shrink: 0;\n        display: flex;\n        margin-right: 55px;\n        width: 110px;\n        height: 110px;\n        background: @black;\n        color: @red;\n        @media @bw1340 {\n            margin-right: 30px;\n        }\n        @media @bw1020 {\n            margin: 0 30px 0 0;\n        }\n        @media @bw768 {\n            margin