EAAA,OAAM,aAAY,GAAA,MAAA,OAAA,CAAA;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderComponent","_ssrRenderAttr","_unref","_push","_parent","_createVNode","_","_scopeId","_openBlock","_createBlock","_resolveDynamicComponent","_Fragment","_renderList","_withAsyncContext","EventCard","_ssrInterpolate","_ssrRenderList"],"sources":["../../../../../../../app/components/the/TheLogo.vue","../../../../../../../app/components/app/AppHero.vue","../../../../../../../app/assets/images/pic1.jpg","../../../../../../../app/assets/images/pic2.jpg","../../../../../../../app/assets/images/pic3.jpg","../../../../../../../app/components/app/AppAbout.vue","../../../../../../../app/components/the/TheSwiper.vue","../../../../../../../app/components/app/AppUpcoming.vue","../../../../../../../app/components/article/ArticleCard.vue","../../../../../../../app/components/app/AppContacts.vue","../../../../../../../app/components/Doit.vue","../../../../../../../app/pages/index.vue"],"sourcesContent":["<template>\n  <div class=\"the-logo\">\n    <div class=\"the-logo__wrapper\">\n        <SvgIcon name=\"logo_big\" class=\"the-logo__icon\"/>\n    </div>\n  </div>\n</template>\n\n<script setup></script>\n\n<style lang=\"less\">\n.the-logo {\n\n    overflow: hidden;\n    \n    &__wrapper {\n        position: relative;\n        margin: 0;\n        width: 1920px + 100px;\n        @media @bw1340 {\n            width: calc(100% + 200px);\n        }\n        @media @bw768 {\n            width: calc(100% + 120px);\n        }\n        &::after {\n            content: \"\";\n            display: block;\n        } \n         @media @bw1340 {\n            width: 1340px;\n        }\n        @media @bw768 {\n            width: 768px;\n        }\n        @media @bw370 {\n            width: 370px;\n        }\n    }\n}\n</style>","<template>\n<!-- Главная - АРТ-ПРОСТРАНСТВО -->\n    <header class=\"app-hero\">\n        <h1 class=\"app-hero__title\">Арт - пространство</h1>\n\n        <TheLogo class=\"app-hero__logo\" />\n\n        <p class=\"app-hero__description\">\n            для людей, горящим сердцем и делом\n            <br />\n            место для настоящего\n        </p>\n    </header>\n  \n</template>\n\n<script setup></script>\n\n\n<style lang=\"less\">\n.app-hero {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    &__title {\n        font-family: @font7;\n        font-size: 45px;\n        font-weight: 400;\n        line-height: 58px;\n        text-align: center;\n        text-transform: uppercase;\n\n        margin: 0;\n        margin-top: 100.5px;\n        margin-bottom: 70.5px;\n\n        @media @bw1340 {\n            margin: 0;\n            margin-top: 100px;\n            margin-bottom: 70px;\n            font-size: 35px;\n            line-height: 45px;\n        }\n        @media @bw768 {\n            margin: 0;\n            margin-top: 80px;\n            margin-bottom: 51px;\n            font-size: 30px;\n            line-height: 38px;\n        }\n        @media @bw370 {\n            margin: 0;\n            margin-top: 80px;\n            margin-bottom: 29px;\n            font-size: 13px;\n            line-height: 17px;\n        }\n    }\n    &__description {\n        display: flex;\n        flex-direction: row;\n        align-items: center;\n        justify-content: center;\n        width: 1340px;\n        height: 116px;\n        font-family: @font7;\n        font-size: 45px;\n        font-weight: 400;\n        line-height: 58px;\n        text-align: center;\n        text-transform: uppercase;\n\n        margin: 0;\n        margin-top: 70px;\n        margin-bottom: 100px;\n\n        @media @bw1340 {\n            width: 1340px;\n            margin: 0;\n            margin-top: 70px;\n            margin-bottom: 100px;\n            font-size: 35px;\n            line-height: 45px;\n            }\n        @media @bw768 {\n            width: 768px;\n            margin: 0;\n            margin-top: 49px;\n            margin-bottom: 73px;\n            font-size: 30px;\n            line-height: 38px;\n        }\n        @media @bw370 {\n            max-width: 100%;\n            margin: 0;\n            margin-top: 28px;\n            margin-bottom: 40px;\n            font-size: 13px;\n            line-height: 17px;\n        }\n    }\n    &__logo {\n         @media @bw1340 {\n            width: 1340px;\n        }\n        @media @bw768 {\n            width: 768px;\n        }\n        @media @bw370 {\n            width: 370px;\n        }\n    }\n}\n</style>\n","export default \"__VITE_ASSET__BYyzb$yj__\"","export default \"__VITE_ASSET__F9FgJ4nS__\"","export default \"__VITE_ASSET__BwkvzoVB__\"","<template>\n<!--Главная-О нас-->\n<section class=\"app-about\">\n    <h2 class=\"app-about__section-title section-title\">О НАС</h2>\n    <div class=\"app-about__container\">\n\n        <div class=\"app-about__block1\">\n            <h3 class=\"app-about__block1-title\">\n            Проект «Millennials»  \n            </h3>\n            <div class=\"app-about__block1-text\">\n                <div class=\"app-about__block1-text--style\">\n                    Вдохновлен молодыми идейными людьми, увлеченными творчеством, эмоциями и желанием \n                    сделать мир лучше, проявить себя. У них есть талант и стремление, у нас возможность помочь\n                    им воплотить их мечту в реальность.\n                </div>\n            </div>\n\n        </div>\n\n        <div class=\"app-about__block2\">\n            <picture class=\"app-about__picture\">\n                <img src=\"@/assets/images/pic1.jpg\" class=\"app-about__img\" alt=\"pic\">\n            </picture>\n            <h3 class=\"app-about__title\">\n                Мы предоставляем площади для вашего мероприятия \n            </h3>\n            <picture class=\"app-about__picture2\">\n                <img src=\"@/assets/images/pic2.jpg\" class=\"app-about__img\" alt=\"pic2\">\n            </picture>\n            <p class=\"app-about__text\">\n            И оказываем помощь с организацией, если вам это нужно. \n            <br>\n            Наша цель: вовлечь в культурную жизнь города как можно больше людей, помочь молодым \n            ребятам сделать первые шаги к своей мечте и рассказать всем о том, что их волнует.\n            </p>\n        </div>\n\n            <div class=\"app-about__block3\">\n               <div class=\"app-about__pic-3\">\n               \n                <div class=\"app-about__red-rectangle\"></div>\n                <img src=\"@/assets/images/pic3.jpg\" class=\"app-about__img-block3\" alt=\"pic3\">\n                </div>\n\n                <div class=\"app-about__text-3\">\n                    Мы уже успешно организовали и\n                    провели более 100 проектов. \n                    Посмотрите, как это было классно.\n                </div>\n\n                \n                <div class=\"app-about__button-3--style\">\n                    <button class=\"app-about__button-3\">\n\n                            <span class=\"app-about__button-3--text\">Смотреть</span>\n                            <span>\n                            <SvgIcon\n                            class=\"more-btn__arrow\"\n                            name=\"arrow\"\n                            width=\"92\"\n                            height=\"62\"\n                            />\n                            </span>\n                    </button>\n                </div>\n        </div>\n\n    </div>\n</section>\n</template>\n\n<script setup></script>\n\n<style lang=\"less\">\n .app-about {\n    box-sizing: border-box;\n    width: 100%;\n    max-width: 1414px;\n    margin: 0 auto;\n    margin-bottom: 100px;\n    padding-left: 40px;\n    padding-right: 40px;\n    \n    @media @bw768 {\n        padding-left: 30px;\n        padding-right: 30px;\n        }\n\n/*     .container;\n\n    &__container {\n        .container(); \n    } */  \n    &__section-title {\n        margin-top: 200px;\n        margin-bottom: 150px;\n        @media @bw1340 {\n            margin-top: 200px;\n            margin-bottom: 130px;\n        }\n        @media @bw768 {\n            margin-top: 130px;\n            margin-bottom: 100px;\n        }\n        @media @bw370 {\n            margin-top: 100px;\n            margin-bottom: 80px;\n        }\n    }\n    &__block1-title {\n        font-family: @font5;\n        font-size: 44px;\n        line-height: 60px;\n        font-weight: bold;\n        @media @bw1340 {\n            font-size: 44px;\n            line-height: 60px;\n        }\n        @media @bw768 {\n            font-size: 26px;\n            line-height: 35px;\n        }\n        @media @bw370 {\n            font-size: 18px;\n            line-height: 25px;\n        }\n    }\n    &__block1-text {\n        display: inline-flex;\n        flex-direction: row;\n        justify-content: flex-end;\n        width: 100%;\n        margin-top: 50.5px;\n        margin-bottom: 100.5px;\n        @media @bw1340 {\n            margin-top: 50.5px;\n            margin-bottom: 100.5px;\n        }\n        @media @bw768 {\n            margin-top: 50px;\n            margin-bottom: 80px;\n        }\n        @media @bw370 {\n            margin-top: 30px;\n            margin-bottom: 60px;\n        }\n    }\n    &__block1-text--style {\n        font-family: @font6;\n        font-size: 18px;\n        line-height: 25px;\n        width: 867px;\n        @media @bw1340 {\n            width: 827px;\n            font-size: 18px;\n            line-height: 25px;\n        }\n        @media @bw768 {\n            width: 637px;\n            font-size: 16px;\n            line-height: 22px;\n        }\n        @media @bw370 {\n            width: 100%;\n            font-size: 16px;\n            line-height: 22px;\n            text-align: left;\n        }\n    }     \n    &__block2 {\n        display: grid;\n        grid-template-columns: 1fr 406px;\n        /* gap: 100px 58px; */\n        grid-template-areas: \n        \"pic pic2\"\n        \"title pic2\"\n        \"text text\";\n        @media @bw1340 {\n            grid-template-columns: 826px 1fr;\n            grid-template-areas: \n            \"pic pic2\"\n            \"title pic2\"\n            \"text text\";\n        }\n        @media @bw768 {\n            width: 709px;\n            grid-template-columns: 419px 1fr;\n            grid-template-areas: \n            \"pic pic\"\n            \"title pic2\"\n            \"text pic2\";\n        }\n        @media @bw370 {\n            grid-template-areas: \n            \"pic\"\n            \"title\"\n            \"text\"\n            \"pic2\";\n        }\n    }\n    &__picture {\n        grid-area: pic;\n        width: 870px;\n        height: 577px;\n        @media @bw1340 {\n            width: 828px;\n            height: 550px;\n        }\n        @media @bw768 {\n            width: 708px;\n            height: 470px;\n            \n        }\n        @media @bw370 {\n            width: 280px;\n            height: 186px;\n        }\n    }\n    &__picture2 {\n        grid-area: pic2;\n        align-self: flex-end; /*Приравнять к низу*/\n        width: 406px;\n        height: 493px;\n        @media @bw1340 {\n            width: 393px;\n            height: 481px;\n            padding-left: 39px;\n        }\n        @media @bw768 {\n            align-self: start;\n            justify-self: end;\n            padding-top: 52px;\n            width: 262px;\n            height: 321px;\n            \n        }\n        @media @bw370 {\n            width: 193px;\n            height: 236px;\n            padding-top: 50px;\n            padding-bottom: 50px;\n            justify-self: start;\n            padding-left: 97px;\n        }\n    }\n    &__title {\n        grid-area: title;\n        margin: 10 px 0 0;\n        font-family: @font5;\n        font-size: 44px;\n        line-height: 60px;\n        font-weight: 700;\n        padding-top: 100px;\n        @media @bw1340 {\n            font-size: 44px;\n            line-height: 60px;\n        }\n        @media @bw768 {\n            width: 419px;\n            padding-top: 79.5px;\n            font-size: 26px;\n            line-height: 35px;\n        }\n        @media @bw370 {\n            width: 280px;\n            font-size: 18px;\n            line-height: 25px;\n            padding-top: 60px;\n            padding-bottom: 30px;\n        }\n    }\n    &__text {\n        grid-area: text;\n        margin: 0 80px 90px auto;\n        max-width: 867px;\n        width: 100%;\n        padding-top: 87px;\n        font-family: @font7;\n        font-size: 18px;\n        font-weight: 400;\n        line-height: 25px;\n        @media @bw1340 {\n            max-width: 827px;\n            font-size: 18px;\n            line-height: 25px;\n        }\n        @media @bw768 {\n            max-width: 348px;\n            padding-top: 40.5px;\n            padding-left: 71px;\n            font-size: 16px;\n            line-height: 22px;\n        }\n        @media @bw370 {\n            max-width: 280px;\n            font-size: 16px;\n            line-height: 22px;\n            padding-top: 30px;\n            padding-left: 0;\n            /* padding-bottom: 50px; */\n            margin: 0;\n        }\n    }\n\n    &__block3 {\n        display: grid;\n        grid-template-columns: 928px 1fr;\n        grid-template-areas: \n        \"pic3 text3\"\n        \"pic3 button3\";\n        @media @bw1340 {\n            grid-template-columns: 867px 1fr;\n        }\n        @media @bw768 {\n            grid-template-columns: 280px 1fr;\n            grid-template-areas: \n            \"pic3 pic3\"\n            \"text3 button3\";\n        }\n        @media @bw370 {\n            grid-template-columns: 267px;\n            grid-template-areas: \n            \"pic3\"\n            \"text3\"\n            \"button3\";\n        }\n    }\n     &__pic-3 {\n        grid-area: pic3;\n        width: 870px;\n        height: 361px;\n        @media @bw1340 {\n            width: 821px;\n            height: 342px;\n        }\n        @media @bw768 {\n            width: 672px;\n            height: 277px;\n        }\n        @media @bw370 {\n            width: 267px;\n            height: 111px;\n        }\n    } \n    &__red-rectangle {\n        background-color: @red;\n        width: 928px;\n        height: 246px;\n        @media @bw1340 {\n            width: 867px;\n            height: 231px;\n        }\n        @media @bw768 {\n            width: 708px;\n            height: 187px;\n        }\n        @media @bw370 {\n            width: 280px;\n            height: 75px;\n        }\n    }\n    &__img-block3 {\n        width: 870px;\n        height: 361px;\n        position: relative;\n        bottom: 228px;\n        left: 49px;\n        @media @bw1340 {\n            bottom: 213px;\n            left: 38px;\n        }\n        @media @bw768 {\n            bottom: 173px;\n            left: 29px;\n        }\n        @media @bw370 {\n            bottom: 70px;\n            left: 11px;\n        }\n        @media @bw1340 {\n            width: 821px;\n            height: 342px;\n        }\n        @media @bw768 {\n            width: 672px;\n            height: 277px;\n        }\n        @media @bw370 {\n            width: 267px;\n            height: 111px;\n        }\n    }\n    &__text-3 {\n        grid-area: text3;\n        width: 353px;\n        font-size: 18px;\n        line-height: 25px;\n        font-weight: 400;\n        align-self: flex-start;\n        padding-left: 62px;\n        padding-top: 155px;\n\n        @media @bw1340 {\n        font-size: 18px;\n        line-height: 25px;\n        width: 353px;\n        padding-left: 40px;\n        padding-top: 137px;\n        }\n        @media @bw768 {\n        font-size: 16px;\n        line-height: 22px;\n        width: 280px;\n        padding-left: 0px;\n        padding-top: 80px;\n        }\n        @media @bw370 {\n        font-size: 16px;\n        line-height: 22px;\n        width: 281px;\n        padding-top: 60px;\n        }\n    }\n    &__button-3 {\n        grid-area: button3;\n    display: flex;\n        flex-direction: row;\n        justify-content: space-between;\n        align-items: center;\n        \n        width: 100%;\n        background-color: transparent;\n        text-decoration: none;\n        border: none;\n\n        font-family: @font1;\n        font-size: 16px;\n        font-weight: 600;\n        line-height: 22px;\n        text-align: right;\n        text-decoration: none;\n        font-weight: bold;\n        font-family: @font1;\n        &:hover,\n        &:active {\n        color: @red_dark;\n        }\n       \n    }\n\n    &__button-3--style {\n        display: flex;\n        flex-direction: row;\n        justify-content: space-between;\n        align-items: center;\n        width: 344px;\n        height: 60px;\n        padding-top: 89px;\n        padding-left: 64px;\n        \n        @media @bw1340 {\n            width: 353px;\n            height: 60px;\n            padding-top: 88px;\n            padding-left: 40px;\n        }\n        @media @bw768 {\n            width: 262px;\n            height: 40px;\n            padding-top: 106px;\n            padding-left: 166px;\n        }\n        @media @bw370 {\n            width: 280px;\n            height: 40px;\n            padding-top: 30px;\n            padding-left: 0px;\n        }\n    }\n}\n</style>","<template>\n<!-- Главная - Мероприятия - Swiper -->\n  <div class=\"the-swiper\">\n    <swiper\n\n    :slides-per-view=\"slidesPerView\"\n    :space-between=\"20\"\n    :breakpoints=\"breakpoints\"\n    :freeMode=\"freeMode\"\n    :speed=\"speed\"\n    :grab-cursor=\"true\"\n\n    :modules=\"[Navigation, Pagination]\"\n    :pagination=\"{ clickable: true, el: '.swiper-pagination-bullets' }\"\n    :navigation=\"{\n      prevEl: '.swiper-arrow-prev',\n      nextEl: '.swiper-arrow-next',\n    }\"\n\n    class=\"the-swiper__slider\"\n    >\n      <swiper-slide\n      v-for=\"(card, cardIndex) in list\"\n      :key=\"cardIndex\"\n      class=\"the-swiper__slider\"\n      > \n      <component :is=\"component\" :data=\"card\" class=\"the-swiper__card\"/>\n      </swiper-slide>\n      <template #container-end>\n        <div class=\"swiper-footer\">\n          <button type=\"button\" class=\"swiper-arrow-prev arrow arrow--left\">\n            <SvgIcon class=\"arrow__icon\" name=\"arrow\" width=\"92\" height=\"62\" />\n          </button>\n\n          <div class=\"swiper-pagination-bullets\"></div>\n\n          <button type=\"button\" class=\"swiper-arrow-next arrow\">\n            <SvgIcon class=\"arrow__icon\" name=\"arrow\" width=\"92\" height=\"62\" />\n          </button>\n        </div>\n      </template>\n    </swiper>\n  </div>\n</template>\n\n<script setup>\n    import { Swiper, SwiperSlide } from \"swiper/vue\";\n    import { Navigation, Pagination } from \"swiper/modules\";\n\n    import \"swiper/css\";\n    import \"swiper/css/pagination\";\n\n    const props = defineProps({\n      component: {\n        type: Object,\n        default: true\n      },\n      list: {\n        type: Array,\n        default: () => []\n      },\n      slidesPerView: {\n        type: [String, Number],\n        default: \"auto\"\n      },\n      spaceBetween: {\n        type: Number,\n        default: 20\n      },\n      \n      breakpoints: {\n      type: Object,\n      default: () => ({\n        768: {\n          slidesPerView: \"auto\",\n          spaceBetween: 30,\n        },\n        1020: {\n          slidesPerView: 3,\n          spaceBetween: 30,\n        },\n        1340: {\n          slidesPerView: 3,\n          spaceBetween: 40,\n        },\n        1660: {\n          slidesPerView: 3,\n          spaceBetween: 60,\n        },\n      }),\n    },\n\n    freeMode: {\n      type: Boolean,\n      default: true,\n    },\n    speed: {\n      type: Number,\n      default: 500,\n    },\n\n    })\n</script>\n\n<style lang=\"less\">\n  .the-swiper {\n    width: 100%;\n    &__slider {\n      width: 100%;\n    }\n\n    .swiper-wrapper {\n      width: 100%;\n    }\n\n    .swiper-slide {\n      display: flex;\n      min-width: 280px;\n\n      @media @bw1020 {\n        width: 280px;\n      }\n\n      & > * {\n        width: 100%;\n      }\n    }\n\n    .swiper-footer {\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      width: 530px;\n      max-width: 100%;\n      margin: 70px auto 0;\n      @media @bw1340 {\n        width: 300px;\n      }\n      @media @bw768 {\n        margin: 60px auto 0;\n      }\n    }\n\n    .swiper-pagination-horizontal.swiper-pagination-bullets {\n      position: relative;\n      display: flex;\n      flex-wrap: wrap;\n      justify-content: center;\n      align-items: center;\n      bottom: auto;\n      left: auto;\n      width: auto;\n      margin: 0 auto;\n      padding: 0 15px;\n    }\n\n    .swiper-pagination-bullet {\n      width: 15px;\n      height: 2px;\n      margin: 2px 3px;\n      border-top: 5px solid transparent;\n      border-bottom: 5px solid transparent;\n      border-radius: 2px;\n      background-color: @gray_dark;\n      background-clip: padding-box;\n      opacity: 1;\n\n      &.swiper-pagination-bullet-active {\n        background-color: @black;\n        background-clip: padding-box;\n      }\n    }\n\n  }\n</style>","<template>\n<!-- Главная - Мероприятия -->\n    <section class=\"app-upcoming\" >\n\n    <div class=\"app-upcoming__wrapper\">\n        <div class=\"app-upcoming__container\">\n            <h2 class=\"app-upcoming__title section-title\">МЕРОПРИЯТИЯ</h2>\n            \n            <TheSwiper \n            :component=\"EventCard\" \n            :list=\"list\" \n            class=\"app-upcoming__swiper\"\n            />\n\n            <!--<div class=\"app-upcoming__swiper\">\n                <EventCard\n                v-for=\"(card, index) in [list[0]]\"\n                :key=\"card.slug\"\n                :data=\"card\"\n                class=\"app-upcoming__card\"\n                /> \n            </div>-->\n\n            <a href=\"#\" class=\"app-upcoming__link link btn-all\">Смотреть все</a>\n\n        </div>\n    </div>\n\n    </section>\n</template>\n\n<script setup>\n    import { EventCard } from \"#components\";\n    //import EventCard from '../event/EventCard.vue';\n\n    const list = ref([]);\n\n    const URL = \"http://localhost:3000/json/events.json\";\n\n    const { data } = await useAsyncData(`upcoming`, () => {\n    return $fetch(URL);\n    });\n    if (data?.value) list.value = data.value;\n</script>\n\n<style lang=\"less\">\n    .app-upcoming {\n        position: relative;\n        width: 100%;\n        padding: 35px 0;\n        overflow: hidden;\n        /* margin-left: 40px; */\n\n            @media @bw1340 {\n                max-width: 1340px;\n            }\n\n        &::before,\n        &::after {\n            content: \"\";\n            display: block;\n            position: absolute;\n            top: 0;\n            width: 0;\n            height: 0;\n            border-bottom: 35px solid fade(@white, 60%);\n        }\n\n        &::before {\n            left: 0;\n            border-right: 34vw solid transparent;\n        }\n        \n        &::after {\n            right: 0;\n            border-left: 66vw solid transparent;\n        }\n\n        &__wrapper {\n            width: 100%;\n            padding: 90px 0;\n            background-color: fade(@white, 60%);\n            &::before,\n            &::after {\n                content: \"\";\n                display: block;\n                position: absolute;\n                bottom: 0;\n                border-top: 35px solid fade(@white, 60%);\n            }\n            &::before {\n                left: 0;\n                border-right: 60vw solid transparent;\n            }\n            &::after {\n                right: 0;\n                border-left: 39vw solid transparent;\n            }\n        }\n\n        &__container {\n            .container();\n            display: flex;\n            flex-direction: column;\n        }\n\n        &__card {\n            display: flex;\n            width: 405px;\n            max-width: 100%;\n            min-width: 280px;\n            margin-right: 58px;\n            width: calc(33.3333% - 158px);\n            margin: 0 29px 120px;\n        }\n    }\n</style>","\n<template>\n<!-- Карточка Блога -->\n    <article class=\"article-card\">\n        <a href=\"#\" class=\"article-card__link\">\n\n            <picture class=\"article-card__picture\">\n\n            <source \n            media=\"(max-width: 450px)\"\n            type=\"image/webp\"\n            :srcset=\"data.img_webp\"\n            />\n            <source media=\"(max-width: 450px)\" :srcset=\"data.img\" />\n\n            <source \n            media=\"(max-width: 1169px)\"\n            type=\"image/webp\"  \n            :srcset=\"data.img_tablet_webp\"/>\n\n            <source media=\"(max-width: 1169px)\" :srcset=\"data.img_tablet\" />\n\n            <source type=\"image/webp\" :srcset=\"data.img_webp\"/>\n\n            <img :src=\"data.img\" alt=\"data.alt\" class=\"article-card__img\"/>\n\n            </picture>\n\n        </a>\n\n        <div class=\"article-card__info\">\n\n            <time :datetime=\"data.date\" class=\"event-card__time\">\n                {{date}}\n            </time>\n\n            <a href=\"#\" class=\"article-card__title-link\">\n\n                <h4 class=\"article-card__title\">\n                    {{data.title}}\n                </h4>\n\n                <div class=\"article-card__arrow arrow\">\n                    <SvgIcon name=\"arrow\" class=\"arrow\" width=\"92\" height=\"62\" />\n                </div>\n\n            </a>\n\n            <p class=\"article-card__description\">\n                {{data.description}}\n            </p>\n        </div>\n\n    </article>\n\n</template>\n\n<script setup>\n\nconst props = defineProps({\ndata: {\n    type: Object,\n    default: () => ({}),\n},\n});\n\nconst date = computed(() => {\ntry {\n    return new Date(props.data.date).toLocaleDateString();\n} catch {\n    return null;\n}\n});\n\n</script>\n\n<style lang=\"less\">\n/* Стилизация карточек блога */\n.article-card {\n\n  box-sizing: border-box;\n  position: relative;\n  display: flex;\n  width: 100%;\n\n  @media @bw1170 {\n    flex-direction: column;\n    max-width: 708px;\n  }\n  @media @bw370 {\n    margin-bottom: 40px;\n  }\n\n  &__info {\n    box-sizing: border-box;\n    position: relative;\n    display: flex;\n    flex-direction: column;\n    width: 100%;\n    padding-left: 63px;\n      @media @bw1340 {\n          padding-left: 60px;\n      }\n      @media @bw768 {\n          padding-top: 20px;\n          padding-left: 0;\n      }\n      @media @bw370 {\n            padding-top: 10px;\n      }\n  }\n\n  &__link {\n\n    &:hover {\n      & ~ .article-card__info {\n        .article-card__title-link {\n          color: @red;\n          text-decoration-color: @red;\n        }\n      }\n    }\n  }\n\n  & + .article-card {\n    margin-top: 120px;\n    @media @bw1340 {\n        margin-top: 110px;    \n    }\n    @media @bw768 {\n        margin-top: 100px;    \n    }\n    @media @bw370 {\n        margin-top: 80px; \n        margin-bottom: 40px;    \n    }\n\n    &::before {\n      content: \"\";\n      display: block;\n      position: absolute;\n      margin: 0 auto 60px;\n      bottom: 100%;\n      left: 0;\n      right: 0;\n      width: 100%;\n      max-width: 1254px;\n      height: 3px;\n      background-color: @black;\n      pointer-events: none;\n    }\n  }\n\n  &__time {\n    margin: 0 0 40px;\n    font-weight: 300;\n    font-size: 16px;\n    line-height: 22px;\n  }\n\n  &__title-link,\n  &__description {\n    max-width: 470px;\n  }\n\n  &__title-link {\n    margin: 70px 0 40px;\n    color: @black;\n    text-decoration-color: transparent;\n    transition: color 0.2s, text-decoration-color 0.2s;\n    &:hover {\n      color: @red;\n      text-decoration-color: @red;\n    }\n    @media @bw768 {\n        margin: 40px 0 20px;\n    }\n    @media @bw370 {\n        margin: 20px 0 10px;   \n    }\n  }\n\n  &__title {\n    margin: 0;\n    color: inherit;\n    font-family: @font5;\n    font-weight: 700;\n    font-size: 24px;\n    line-height: 33px;\n    @media @bw768 {\n        font-size: 20px;\n        line-height: 27px;\n    }\n    @media @bw370 {\n        font-size: 16px;\n        line-height: 22px; \n    }\n  }\n\n  &__description {\n    margin: 0;\n    font-family: @font6;\n    font-size: 16px;\n    line-height: 22px;\n    font-weight: 400;\n    @media @bw370 {\n        font-size: 14px;\n        line-height: 19px; \n    }\n  }\n\n  &__arrow {\n    position: absolute;\n    right: 0;\n    bottom: 30px;\n    color: inherit;\n    transition: none;\n    @media @bw768 {\n        bottom: 0px;\n        }\n    @media @bw370 {\n        bottom: -40px;  \n    }\n  }\n  \n}\n\n</style>\n","<template>\n<!--Главная-Контакты-->\n <section class=\"app-contacts\">\n\n  <h2 class=\"app-contacts__section-title section-title\">КОНТАКТЫ</h2>\n\n  <div class=\"app-contacts__wrapper\">\n\n        <ul class=\"app-contacts__list\">\n\n            <li class=\"app-contacts__item\" >\n                <div class=\"app-contacts__item-mark\">\n                    <SvgIcon class=\"app-contacts__item-icon\" name=\"location\"/>\n                </div>\n                <div class=\"app-contacts__item-content\">\n                    <h2 class=\"app-contacts__item-title\">\n                    Томск, Красноармейская 146\n                    </h2>\n                    <div class=\"app-contacts__item-info\">\n                    2 этаж\n                    </div>\n                    <div class=\"app-contacts__item-info\">\n                    оф. 206\n                    </div>\n                </div>\n            </li>\n\n            <li class=\"app-contacts__item\" >\n  