{"file":"index-DWJK4hHL.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAsDI,UAAM,QAAQ;AAOd,UAAM,UAAU;AAAA,MAAS,MACrB,MAAM,QAAQ,MAAM,KAAK,OAAO,IAAI,MAAM,KAAK,UAAU,CAAA;AAAA,IACjE;AAEI,UAAM,OAAO;AAAA,MAAS,MAClB,MAAM,QAAQ,MAAM,KAAK,IAAI,IAAI,MAAM,KAAK,OAAO,CAAA;AAAA,IAC3D;;AAhEW,YAAA,SAAAA,eAAAC,WAAA,EAAA,OAAM,eAAW,MAAA,CAAA,CAAA,wGAAA;oBAKYC,MAAA,OAAA,GAAO,CAAvB,IAAG,YAAO;0DAIX,EAAE,CAAA,OAAA;AAAA;;oBAMUA,MAAA,IAAA,GAAI,CAAnB,IAAG,YAAO;AAIP,cAAA,4DAAAC,eAAA,GAAG,MAAM,CAAA,eAAA;AAGOC,sBAAA,GAAG,QAAM,CAAxB,IAAG,YAAO;;AAIN,cAAA,aAAa,OAAE,WAAA;;;4CAEpB,EAAE,CAAA,UAAA;AAAA;;;;;;oBAUmBF,MAAA,OAAA,GAAO,CAAvB,IAAG,YAAO;iEAIX,EAAE,CAAA,OAAA;AAAA;;;;;;;;;;;;;;;AC3B7B,UAAM,SAAS,IAAI;AAAA,MACX,SAAS,CAAC,iBAAiB,iBAAiB,mBAAmB;AAAA,MAC/D,MAAM;AAAA,QACF;AAAA,UACI,QAAQ;AAAA,UACR,QAAQ,CAAC,WAAW,WAAW,SAAS;AAAA,QACxD;AAAA,QACY;AAAA,UACI,QAAQ;AAAA,UACR,QAAQ,CAAC,IAAI,MAAM,IAAI;AAAA,QACvC;AAAA,QACY;AAAA,UACI,QAAQ;AAAA,UACR,QAAQ,CAAC,MAAM,MAAM,IAAI;AAAA,QACzC;AAAA,QACY;AAAA,UACI,QAAQ;AAAA,UACR,QAAQ,CAAC,IAAI,IAAI,IAAI;AAAA,QACrC;AAAA,QACY;AAAA,UACI,QAAQ;AAAA,UACR,QAAQ,CAAC,IAAI,MAAM,IAAI;AAAA,QACvC;AAAA,QACY;AAAA,UACI,QAAQ;AAAA,UACR,QAAQ,CAAC,IAAI,IAAI,IAAI;AAAA,QACrC;AAAA,QACY;AAAA,UACI,QAAQ;AAAA,UACR,QAAQ,CAAC,IAAI,MAAM,IAAI;AAAA,QACvC;AAAA,QACY;AAAA,UACI,QAAQ;AAAA,UACR,QAAQ,CAAC,IAAI,IAAI,IAAI;AAAA,QACrC;AAAA,QACY;AAAA,UACI,QAAQ;AAAA,UACR,QAAQ,CAAC,IAAI,IAAI,IAAI;AAAA,QACrC;AAAA,MACA;AAAA,IACA,CAAK;;;;;QA7CM,MAAMA,MAAA,MAAA;AAAA,QAAQ,OAAM;AAAA;;;;;;;;;;;;;;;;;;;;ICF3B,OAAM;AAAA,IACL,OAAO;AAAA,IACP,SAAS;AAAA,IACT,KAAK;AAAA;qBALN,CAea,EAAA,KAAA,GAAAG,QAAAC,UAAA,aAAA;;;AANEF,sBAAA,OAAR,SAAI;;YACV,KAAK,KAAK;AAAA,YACV,MAAM;AAAA,YACP,OAAM;AAAA;;;;;4BAJNG,YAKEC,UAAA,MAAAC,WAJa,MAAI,CAAZ,SAAI;gCADXF,YAKE,sBAAA;AAAA,cAHD,KAAK,KAAK;AAAA,cACV,MAAM;AAAA,cACP,OAAM;AAAA;;;;;;;AAKO,QAAAG,mBAAA,wBAAA,EAAA,OAAM,mBAAkB,GAAA,MAAA,OAAA,CAAA;AAE1B,QAAAA,mBAAA,sBAAA,EAAA,OAAM,iBAAgB,GAAA,MAAA,OAAA,CAAA;;;IAUR,OAAM;AAAA,IAA6B,MAAK;AAAA;;;IAcxC,OAAM;AAAA,IAA6B,MAAK;AAAA;;;IAmBxC,OAAM;AAAA,IAA6B,MAAK;AAAA;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_unref","_ssrInterpolate","_ssrRenderList","_push","_parent","_createBlock","_Fragment","_renderList","_ssrRenderComponent"],"sources":["../../../../../../../app/components/app/AppTable.vue","../../../../../../../app/components/app/AppServices.vue","../../../../../../../app/pages/events/index.vue"],"sourcesContent":["\n <template>\n<!-- Страница Мероприятия/Таблица с тарифами -->\n    <table class=\"app-table\">\n        <thead class=\"app-table__head\">\n            <tr class=\"app-table__head-tr\">\n                <th class=\"app-table__th\"></th>\n                <th \n                v-for=\"(th,thIndex)  in headers\"\n                :key=\"thIndex\"\n                class=\"app-table__th\"\n                >  \n                    {{ th }}\n                </th>\n            </tr>\n        </thead>\n        <tbody class=\"app-table__body\">\n            <tr \n            v-for=\"(tr,trIndex) in rows\"\n            :key=\"trIndex\"\n            class=\"app-table__tr\">\n                <th class=\"app-table__body-th\">\n                    {{ tr.header }}\n                </th>\n                <td \n                v-for=\"(td,tdIndex) in tr.values\"\n                :key=\"tdIndex\" \n                class=\"app-table__td\"\n                >\n                <span v-if=\"td && typeof td === 'boolean'\" class=\"ok\"></span>\n                <template v-else>\n                    {{ td }}\n                </template>\n                </td>\n            </tr>\n        </tbody>\n\n        <tfoot class=\"app-table__footer\">\n            <tr class=\"app-table__footer-tr\">\n                <th class=\"app-table__footer-th\"></th>\n                <th \n                    v-for=\"(th,thIndex)  in headers\"\n                    :key=\"thIndex\"\n                    class=\"app-table__footer-th\"\n                    >\n                        {{ th }}\n                </th>\n            </tr>\n        </tfoot>\n    </table>\n\n</template>\n\n<script setup>\n    const props = defineProps ({\n        data: {\n            type: Object,\n            default: () => ({}),\n        },\n    });\n\n    const headers = computed(() => \n        Array.isArray(props.data.headers) ? props.data.headers : [],\n    );\n\n    const rows = computed(() => \n        Array.isArray(props.data.data) ? props.data.data : [],\n    );\n</script>\n\n<style lang=\"less\">\n.app-table {\n    margin: auto;\n    max-width: 1334px;\n    width: 100%;\n    border-collapse: collapse;\n    color: @black;\n    text-align: center;\n\n    @media @bw1340 {\n        width: 1260px; \n    }\n    @media @bw768 {\n        width: 708px;\n    }\n    @media @bw370 {\n        width: 320px;\n    }\n    @media @bw768 {\n        display: block;\n        margin: 0 -20px;\n    }\n\n    &__head,\n    &__body,\n    &__footer {\n        @media @bw768 {\n            display: block;\n        }\n    }\n\n    &__head-tr {\n        @media @bw768 {\n            display: flex;\n            /* width: 100%; */\n        }\n    }\n\n    &__th,\n    &__footer-th {\n\n        @media @bw768 {\n            box-sizing: border-box;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            text-transform: uppercase;\n            height: auto;\n            width: 33.333%;\n            padding: 20px 5px;\n            font-size: 14px;\n        }\n\n        br {\n            display: none;\n                @media @bw768 {\n                    display: block;\n                }\n            }\n\n        &:first-child {\n            @media @bw768 {\n                display: none;\n            }\n        }\n\n        &:nth-child(2){\n            @media @bw768 {\n                padding-left: 15px;\n            }\n        }\n\n        &:nth-child(2n-1){\n            @media @bw768 {\n                background-color: fade(#1F1E1E, 3%);\n            }\n        }\n\n        &:last-child{\n            padding-right: 15px;\n        }\n    }\n\n    &__tr {\n        @media @bw768 {\n            display: flex;\n            flex-wrap: wrap;\n        }\n        &:nth-child(2n-1) {\n            background-color: fade(#1F1E1E, 3%);\n                @media @bw768 {\n                    background-color: transparent;\n                }\n    }\n    }\n\n    &__th {\n        height: 85px;\n        font-weight: 600;\n        font-size: 18px;\n        line-height: 25px;\n        @media @bw1020 {\n            font-size: 14px;\n        }\n        @media @bw768 {\n            font-size: 14px;\n            font-weight: 600;\n            line-height: 19px;\n        }\n        br {\n            display: none;\n            @media @bw768 {\n                display: block;\n            }\n        }\n    }\n\n    &__footer-tr {\n        @media @bw768 {\n            //display: flex;\n            //border-top: 1px solid #BFBFBF;\n            display: none;\n        }\n        @media @bw370 {\n            display: flex;\n            border-top: 1px solid #BFBFBF;\n            font-family: @font6;\n            font-weight: 300;\n            opacity: 50%;\n        }\n    }\n\n    &__footer-th {\n        height: 60px;\n        font-size: 0;\n        @media @bw768 {\n            margin-top: 20px;\n            font-size: 16px;\n        }\n    }\n\n    &__th,\n    &__footer-th {\n        box-sizing: border-box;\n        padding: 10px;\n        border-right: 1px solid #BFBFBF;\n        text-transform: uppercase;\n        &:first-child {\n            padding-left: 0;\n        }\n        &:last-child {\n            border-right: none;\n            padding-right: 0;\n        }\n    }\n\n    &__body-th {\n        box-sizing: border-box;\n        height: 50px;\n        padding: 10px 10px 10px 0;\n        border-top: 1px solid #BFBFBF;\n        border-bottom: 1px solid #BFBFBF;\n        font-weight: 400;\n        font-size: 18px;\n        line-height: 25px;\n        text-align: left;\n        @media @bw768 {\n            display: block;\n            width: 100%;\n            text-align: center;\n            font-weight: 600;\n            padding: 13px 15px;\n            font-size: 14px;\n        }\n    }\n\n    &__td {\n        box-sizing: border-box;\n        height: 50px;\n        padding: 10px;\n        border: 1px solid #BFBFBF;\n        font-weight: 600;\n        font-size: 16px;\n        line-height: 22px;\n\n        @media @bw768 {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            width: 33.333%;\n            border: none;\n            border-right: 1px solid #BFBFBF;;\n        }\n\n        &:nth-child(2) {\n            @media @bw768 {\n                padding-left: 20px;\n            }\n        }\n\n        &:nth-child(2n-1){\n            @media @bw768 {\n                background-color: fade(#1F1E1E, 3%);\n            }\n        }\n\n        &:last-child {\n            border-right: none;\n            padding-right: 0;\n            @media @bw768 {\n                padding-right: 20px;\n            }\n        }\n    }\n}\n\n.ok {\ndisplay: block;\nposition: relative;\nwidth: 26px;\nheight: 26px;\nmargin: auto;\nborder-radius: 50%;\nbackground-color: #1F1E1E;\n    &::after {\n        content: \"\";\n        box-sizing: border-box;\n        display: block;\n        position: absolute;\n        top: 4px;\n        left: 9px;\n        width: 8px;\n        height: 14px;\n        border-right: 2px solid #ffffff;\n        border-bottom: 2px solid #ffffff;\n        transform: rotate(45deg);\n    }\n}\n</style>","<template>\n <!-- Страница Мероприятия Раздел Дополнительные услуги -->\n    <div class=\" app-services\">\n        <h2 class=\"section-title app-services__title\">\n            Дополнительные услуги\n        </h2>\n        <p class=\"app-events__section-description\">\n            Перед запуском проекта, мы подготавливаем подробную смету и согласуем ее с клиентом. Убедившись, что \n            все пожеланию учтены и мы можем приступать к реализациии проекта, начинается сложная, но интересная \n            работа, результатом которой будет проведение вашего мероприятия на высшем уровне.\n        </p>\n\n    </div>\n<AppTable :data=\"tarifs\" class=\"app-events__tariffs-table\"/>\n\n</template>\n\n<script setup>\nconst tarifs = ref({\n        headers: [\"Тариф «Light»\", \"Тариф «Promo»\", \"Тариф «All stars»\"],\n        data: [\n            {\n                header: \"Стоимость за час\",\n                values: [\"1 000 ₽\", \"3 000 ₽\", \"3 000 ₽\"],\n            },\n            {\n                header: \"Ведущий мероприятия\",\n                values: [\"\", true, true],\n            },\n            {\n                header: \"Фотосъемка\",\n                values: [true, true, true],\n            },\n            {\n                header: \"Видеосъемка\",\n                values: [\"\", \"\", true],\n            },\n            {\n                header: \"Организация питания\",\n                values: [\"\", true, true],\n            },\n            {\n                header: \"Декор\",\n                values: [\"\", \"\", true],\n            },\n            {\n                header: \"Звуковое сопровождение\",\n                values: [\"\", true, true],\n            },\n            {\n                header: \"Дополнительное освещение\",\n                values: [\"\", \"\", true],\n            },\n            {\n                header: \"Клининг\",\n                values: [\"\", \"\", true],\n            },\n        ],\n    });\n</script>\n\n<style lang=\"less\">\n.app-events {\n    padding: 140px 0 20px; /*сверху 140px, слево/справа 0, снизу 150px*/\n    max-width: 1920px;\n    margin: auto;\n\n    &__listing {\n        margin-bottom: 100px;\n        \n    }\n\n    &__section-description {\n        max-width: 868px;\n        margin-bottom: 60px;\n        @media @bw1340 {\n            max-width: 828px;\n            margin-bottom: 60px;\n        }\n        @media @bw768 {\n            width: 100%;\n            margin-bottom: 50px;\n        }\n        @media @bw370 {\n            margin-bottom: 30px;\n        }\n    }\n    &__section-title {\n        font-size: 22px;\n        margin-top: 100px;\n        margin-bottom: 150px;\n        @media @bw1340 {\n            padding-left: 130px;\n        }\n        @media @bw768 {\n            padding-left: 100px;\n        }\n        @media @bw370 {\n            font-size: 16px;\n            padding-left: 80px;\n        }\n    }\n    &__button {\n        position: relative;\n        display: flex;\n        flex-direction: column;\n        align-items: center; /* Выравнивание по вертикали */\n        justify-content: center; /* Выравнивание по горизонтали */\n        padding: 10px 20px; /* Отступы внутри кнопки */\n        margin: auto;\n        width: 128px;\n        height: 132px;\n    }\n    \n    &__button-icon {\n        padding-top: 20px;\n        background-color: none;\n        rotate: 90deg;\n    }\n\n    &__button-link {\n        text-decoration: none;\n    }\n\n    &__button-text {\n        font-family: @font1;\n    }\n}\n.app-services {\n  .container;\n  &__title {\n    margin-top: 100px;\n    margin-bottom: 150px;\n    font-family: @font7;\n    font-size: 22px;\n    font-weight: 400;\n        @media @bw1340 {\n            margin-top: 100px;\n            margin-bottom: 130px;\n        }\n        @media @bw768 {\n            margin-top: 100px;\n            margin-bottom: 100px;\n        }\n        @media @bw370 {\n            margin-top: 100px;\n            margin-bottom: 80px;\n            font-size: 16px;\n            font-weight: 500;\n        }\n  }\n}\n</style>","\n<template>\n<!-- Раздел Мероприятия - Главная/Мероприятия-->\n  <div class=\"page-title\">\n    <span class=\"page-title__style\">Главная / Мероприятия</span>\n  </div>\n\n  <div class=\"events\">\n\n    <AppListing \n    v-slot=\"{ list }\"\n    class=\"events__listing\"\n    :title=\"'Мероприятия'\"\n    :moreBtn=\"true\"\n    :url=\"'/json/events.json'\"\n    >\n\n    <EventCard\n    v-for=\"card in list\"\n    :key=\"card.slug\"\n    :data=\"card\"\n    class=\"app-listing__card\"\n    />\n\n    </AppListing>\n\n    <AppServices class=\"events__services\"/>\n\n    <AppOffers class=\"events__offers\"/>\n\n  </div>\n\n  <div class=\"events-contacts__wrapper\">\n\n        <ul class=\"events-contacts__list\">\n\n            <li class=\"events-contacts__item\" >\n                <div class=\"events-contacts__item-mark\">\n                    <SvgIcon class=\"events-contacts__item-icon\" name=\"information\"/>\n                </div>\n                <div class=\"events-contacts__item-content\">\n                    <h2 class=\"events-contacts__item-title\">\n                    Цены\n                    </h2>\n                    <div class=\"events-contacts__item-info\">\n                    Цены, указанные на сайте носят информационный характер. Мы придерживаемся индивидуального подхода в работе с клиентом.\n                    </div>\n                </div>\n            </li>\n\n            <li class=\"events-contacts__item\" >\n                <div class=\"events-contacts__item-mark\">\n                    <SvgIcon class=\"events-contacts__item-icon\" name=\"contact\"/>\n                </div>\n                <div class=\"events-contacts__item-content\">\n                    <h2 class=\"events-contacts__item-title\">\n                    Контакты\n                    </h2>\n                    <div class=\"events-contacts__item-info\">\n                        Отдел организации мероприятий\n                    </div>\n                    <div class=\"events-contacts__item-info\">\n                        <a href=\"mailto:idat@tusur.ru\" class=\"events-contacts__item-info\">\n                            idat@tusur.ru\n                        </a>\n                    </div>\n                </div>\n            </li>\n\n            <li class=\"events-contacts__item\">\n                <div class=\"events-contacts__item-mark\">\n                    <SvgIcon class=\"events-contacts__item-icon\" name=\"handshake\"/>\n                </div>\n                <div class=\"events-contacts__item-content\">\n                    <h2 class=\"events-contacts__item-title\">\n                    Преимущество\n                    </h2>\n                    <div class=\"events-contacts__item-info\">\n                        Мы имеем все возможности для того, чтобы помочь как малому бизнесу и молодым талантам, так и большим корпорациям и холдингам.\n                    </div>\n                </div>\n            </li>\n        </ul>\n\n    </div>\n\n</template>\n\n<script setup></script>\n\n<style lang=\"less\">\n  .events {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n\n    &__offers {\n      margin-bottom: 100px;\n      @media @bw768 {\n        margin-bottom: 90px;\n      }\n    }\n  }\n\n  .app-listing{\n    max-width: 1340px;\n    width: 100%;\n    margin: auto;\n    &__list {\n      display: flex;\n      flex-direction: row;\n      flex-wrap: wrap;\n      justify-content: center;\n    }\n    &__card {\n      max-width: 400px;\n      padding: 20px;\n    }\n  }\n</style>"],"version":3}